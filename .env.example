# Wyze account credentials
WYZE_EMAIL=your@email.com
WYZE_PASSWORD=yourpassword

# Wyze API key — generate at https://developer-api-console.wyze.com/
WYZE_KEY_ID=your_key_id
WYZE_API_KEY=your_api_key

# Garmin Connect credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# How often to sync (minutes). Default: 30
SYNC_INTERVAL=30
